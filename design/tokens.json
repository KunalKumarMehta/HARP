{
  "$name": "HARP brand tokens",
  "$version": "0.2.0",
  "$description": "Design tokens for HARP — the 'Instrument' identity. The brand reads as a precision measuring instrument: warm paper and ink, with the routing decision itself as the motif — on-device (teal) vs cloud (amber), split at the conformal threshold δ. Consume the primitive scales for building blocks; consume `theme.paper` (light) or `theme.scope` (dark instrument panel) for ready-made surface/text/border roles.",
  "color": {
    "$description": "Primitive palette. Semantic roles live under `theme`.",
    "brand": {
      "primary": "#0E7561",
      "primaryHover": "#0A5445",
      "primaryMuted": "#0F7D6B"
    },
    "lane": {
      "$description": "Maps 1:1 to the router's decision, so the story reads at a glance: on-device vs escalate.",
      "local": "#0E7561",
      "localMuted": "#0A5445",
      "cloud": "#C0561B",
      "cloudMuted": "#94420F",
      "shed": "#C0561B",
      "offline": "#7C7C6E"
    },
    "paper": {
      "$description": "Warm instrument-paper surfaces (the light world).",
      "base": "#E7E2D4",
      "panel": "#EFEBDF",
      "panel2": "#E0DAC8",
      "rule": "#C7C0AD"
    },
    "ink": {
      "$description": "Text on paper.",
      "strong": "#191A17",
      "body": "#4B4C42",
      "muted": "#7C7C6E"
    },
    "scope": {
      "$description": "Dark instrument-screen surfaces (the dark world); signals glow here.",
      "base": "#191C17",
      "panel": "#20241D",
      "line": "#333A2E",
      "ink": "#D8DAC9",
      "muted": "#8B917D",
      "local": "#3FC6A6",
      "cloud": "#F0913E"
    },
    "signal": {
      "success": "#0E7561",
      "warning": "#C0561B",
      "danger": "#B23A2A",
      "info": "#0E7561"
    }
  },
  "typography": {
    "fontFamily": {
      "$description": "Space Grotesk for display headlines; IBM Plex Sans for body prose; IBM Plex Mono for all labels, data, and readouts (the signature 'everything is a readout' texture).",
      "display": "'Space Grotesk', ui-sans-serif, system-ui, sans-serif",
      "sans": "'IBM Plex Sans', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "mono": "'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
    },
    "fontSize": {
      "$description": "Modular scale, ratio 1.25 (major third), base 16px.",
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "md": "1.125rem",
      "lg": "1.25rem",
      "xl": "1.563rem",
      "2xl": "1.953rem",
      "3xl": "2.441rem",
      "4xl": "3.052rem"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.05,
      "snug": 1.3,
      "normal": 1.6,
      "relaxed": 1.75
    },
    "letterSpacing": {
      "tight": "-0.03em",
      "normal": "0em",
      "label": "0.16em"
    }
  },
  "space": {
    "$description": "4px base scale.",
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "radius": {
    "sm": "5px",
    "md": "9px",
    "lg": "14px",
    "pill": "999px"
  },
  "border": {
    "width": { "hairline": "1px", "thick": "2px" }
  },
  "shadow": {
    "sm": "0 1px 2px rgba(25,26,23,0.10)",
    "md": "0 8px 24px rgba(25,26,23,0.14)",
    "lg": "0 30px 60px -34px rgba(25,28,23,0.70)"
  },
  "theme": {
    "paper": {
      "$description": "Warm paper — documentation / content surfaces.",
      "color": {
        "bg": "#E7E2D4",
        "surface": "#EFEBDF",
        "surfaceElevated": "#EFEBDF",
        "text": "#191A17",
        "textMuted": "#4B4C42",
        "border": "#C7C0AD",
        "accent": "#0E7561",
        "accentText": "#E7E2D4",
        "laneLocal": "#0E7561",
        "laneCloud": "#C0561B"
      }
    },
    "scope": {
      "$description": "Dark instrument panel — hero / presentation / signature surfaces.",
      "color": {
        "bg": "#191C17",
        "surface": "#20241D",
        "surfaceElevated": "#262B22",
        "text": "#D8DAC9",
        "textMuted": "#8B917D",
        "border": "#333A2E",
        "accent": "#3FC6A6",
        "accentText": "#191C17",
        "laneLocal": "#3FC6A6",
        "laneCloud": "#F0913E"
      }
    }
  }
}
