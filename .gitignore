# OS / editor
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Local tooling / agent config
.claude/

# Research, working notes, decks, role playbooks — kept out of the public repo.
# docs/ itself is tracked (engineering docs); only the archive is ignored.
docs/archive/

# Build artifacts & large binaries
build/
*.exe
*.zip

# Secrets, credentials, local test keys — never commit these
*.pem
*_TESTING_KEY.*

# Generated benchmark evidence
evidence_pack*.md
evidence_pack*.json

# Demo runtime state (regenerated each run; the calibration evidence IS committed)
mac_demo/harp_notes.jsonl

# local validation venv (hermes branch)
.venv-hermes/

# Synthetic routing dataset (regenerated by data/synth_routing_data.py; do not commit)
routing_dataset/

# HF scout reports (regenerated on demand; never commit raw API dumps)
scout_report_*.json

# Score-head eval reports (regenerated by evals/eval_score_head.py; do not commit)
eval_report_*.json

# MLX score-head weights (regenerated by train/train_score_head.py; do not commit)
train/mlx_score_head.json
